# Secrets / local config — never committed (CLAUDE.md)
.env
*.env
!.env.example

# Local uploaded images (filesystem StorageService root) — runtime data, not source
data/

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
.mvn/.develocity/

# Node (admin-ui, added in T15)
node_modules/
admin-ui/dist/
admin-ui/node/
# Built SPA bundle — generated by the frontend-maven-plugin at build time
src/main/resources/static/admin/

# Design references (handoff bundles — not shippable code)
design_handoff_nemiskacat_admin/

# Claude Code local state — git worktrees (checked out as gitlinks) and per-machine
# session data must never be committed. Shared project config under .claude/ (agents,
# skills, settings) can be force-added with `git add -f` if desired.
.claude/worktrees/
.claude/**/*.local.json
.claude/todos/
.claude/shell-snapshots/

# IDE / OS
.idea/
*.iml
.vscode/
.DS_Store
