# Copy to .env for local overrides. .env is gitignored and must never contain
# production secrets that reach the repo or any Claude prompt (CLAUDE.md).
# Loaded via spring.config.import in application.yml (KEY=VALUE parses as properties).

# --- Database (defaults target the local compose.yaml Postgres) ---
DB_URL=jdbc:postgresql://localhost:5432/webshop
DB_USERNAME=webshop
DB_PASSWORD=webshop

# --- Added in later tasks (kept here as documentation) ---
